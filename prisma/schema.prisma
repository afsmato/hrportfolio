// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon connection pooling (PgBouncer) - use for serverless functions
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ============================================================
// NextAuth.js v5 required models
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// Application models
// ============================================================

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  name             String
  image            String?
  bio              String?   @db.VarChar(200)
  domain           String    @default("people_analytics_od")
  careerGoal       String?
  dataShareConsent Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  skillAssessments  SkillAssessment[]
  learningItems     LearningItem[]
  notificationLogs  NotificationLog[]
  bookSurveyResponses BookSurveyResponse[]
  learningArchives  LearningArchive[]
  userCertifications UserCertification[]
  chatMessages      ChatMessage[]
}

model SkillAssessment {
  id         String   @id @default(cuid())
  userId     String
  skillId    String
  score      Int      // 1-5
  assessedAt DateTime @default(now())
  note       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, skillId])
}

model ArticleSource {
  id       String    @id @default(cuid())
  name     String
  url      String    @unique
  category String
  active   Boolean   @default(true)

  articles Article[]
}

model Article {
  id          String   @id @default(cuid())
  sourceId    String
  title       String
  url         String   @unique
  summary     String   @db.Text
  publishedAt DateTime
  tags        Json     // SkillId[]
  difficulty  String
  category    String
  fetchedAt   DateTime @default(now())

  source        ArticleSource  @relation(fields: [sourceId], references: [id])
  learningItems LearningItem[]

  @@index([publishedAt])
  @@index([category])
}

model Book {
  id              String   @id @default(cuid())
  isbn            String   @unique
  title           String
  author          String
  publisher       String
  publishedDate   String   // YYYY-MM format
  imageUrl        String?
  rakutenItemCode String?
  amazonAsin      String?
  isClassic       Boolean  @default(false)
  claudeSkillTags Json     // SkillId[]
  createdAt       DateTime @default(now())

  learningItems       LearningItem[]
  bookSkillTags       BookSkillTag[]
  bookSurveyResponses BookSurveyResponse[]
}

model LearningItem {
  id          String    @id @default(cuid())
  userId      String
  type        String    // 'article' | 'book'
  articleId   String?
  bookId      String?
  status      String    // 'queued' | 'completed'
  skillIds    Json      // SkillId[]
  memo        String?   @db.Text
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id])
  book    Book?    @relation(fields: [bookId], references: [id])

  @@index([userId])
  @@index([userId, status])
}

model NotificationLog {
  id        String    @id @default(cuid())
  userId    String
  type      String    // 'review_reminder' | 'survey'
  sent      Boolean   @default(false)
  sentAt    DateTime?
  surveyed  Boolean?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
}

model Certification {
  id          String   @id @default(cuid())
  name        String
  provider    String   // "AIHR", "SHRM", "HRCI", etc.
  skillIds    Json     // SkillId[]
  level       Int      // 対応スキルレベル目安 (1-5)
  url         String?
  createdAt   DateTime @default(now())

  userCertifications UserCertification[]
}

model UserCertification {
  id              String    @id @default(cuid())
  userId          String
  certificationId String
  status          String    // 'completed' | 'in_progress' | 'planned'
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification Certification @relation(fields: [certificationId], references: [id])

  @@unique([userId, certificationId])
  @@index([userId])
}

model LearningArchive {
  id          String   @id @default(cuid())
  userId      String
  period      String   // "2026-03" (月次)
  periodStart DateTime
  periodEnd   DateTime
  summary     String   @db.Text
  isConfirmed Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId])
}

model TrendReport {
  id          String   @id @default(cuid())
  generatedAt DateTime @default(now())
  periodFrom  DateTime
  periodTo    DateTime

  keywords TrendKeyword[]
}

model TrendKeyword {
  id              String @id @default(cuid())
  trendReportId   String
  rank            Int
  keyword         String
  relatedSkillIds Json   // SkillId[]
  articleCount    Int

  trendReport TrendReport @relation(fields: [trendReportId], references: [id], onDelete: Cascade)

  @@index([trendReportId])
}

model BookSkillTag {
  id                String   @id @default(cuid())
  bookId            String
  skillId           String
  count             Int      @default(0)
  avgSkillLevelAtRead Float  @default(0)
  updatedAt         DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, skillId])
  @@index([bookId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // 'user' | 'assistant'
  content   String   @db.Text
  sources   Json     @default("[]")  // [{title: string, url?: string}]
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model BookSurveyResponse {
  id               String    @id @default(cuid())
  userId           String
  bookId           String
  response         String    // 'read' | 'queued' | 'skipped'
  skillIds         Json      // SkillId[] (empty if not 'read')
  skillLevelAtRead Int?
  respondedAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
  @@index([bookId])
}
