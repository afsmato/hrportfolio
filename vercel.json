{
  "functions": {
    "src/app/api/cron/fetch-books/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/fetch-articles",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/fetch-books",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/generate-trends",
      "schedule": "0 1 1 * *"
    },
    {
      "path": "/api/cron/generate-summaries",
      "schedule": "0 2 1 * *"
    }
  ]
}
